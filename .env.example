# =============================================================
#  ExcelDraw — environment template for the WHOLE monorepo
#  Copy the values you need into the real .env files (see notes).
#  Nothing here is auto-magically loaded by this root file — it is
#  documentation. Each variable below says WHERE it must live.
# =============================================================

# -------------------------------------------------------------
# 1) DATABASE_URL   — REQUIRED. Used by Prisma (packages/database).
#    Lives in:  packages/database/.env
#    Prisma reads it for `migrate`/`generate` and the backends'
#    PrismaClient reads it at runtime (auto-loaded from the schema dir).
#
#    Local Postgres example:
#      postgresql://postgres:YOUR_PASSWORD@localhost:5432/exceldraw?schema=public
#    Hosted (Neon/Supabase/Railway) example:
#      postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require
# -------------------------------------------------------------
DATABASE_URL="postgresql://postgres:YOUR_PASSWORD@localhost:5432/exceldraw?schema=public"

# -------------------------------------------------------------
# 2) JWT_SECRET    — OPTIONAL (code falls back to a baked-in dev value).
#    Used by:  apps/http-backend  AND  apps/websockets
#              (both import it from packages/backend-common).
#    MUST be identical for both services or tokens won't verify.
#    Set a strong random value for anything non-local. To make the
#    backends actually read it you must export it in the shell that
#    launches them (the backends do not load .env on their own):
#      PowerShell:  $env:JWT_SECRET = "your-long-random-secret"
# -------------------------------------------------------------
JWT_SECRET="change-me-to-a-long-random-string"

# -------------------------------------------------------------
# 3) Frontend → backend endpoints
#    NOTE: currently HARD-CODED in apps/excel_front/config.ts
#          (HTTP_BACKEND = http://localhost:4000,
#           WS_URL       = ws://localhost:8080).
#    They are NOT read from env today. Listed here only so you know
#    what to change if you deploy the backends elsewhere.
# -------------------------------------------------------------
# HTTP_BACKEND="http://localhost:4000"
# WS_URL="ws://localhost:8080"
